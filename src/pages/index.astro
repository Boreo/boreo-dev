---
import { profile, certifications } from '../data/site';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={`${profile.name} — ${profile.title}`} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href="https://boreo.dev/" />
    <meta property="og:title" content={profile.name} />
    <meta property="og:description" content={`${profile.title} — certifications, projects, and links.`} />
    <meta property="og:url" content="https://boreo.dev/" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="https://boreo.dev/og.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{profile.name}</title>
  </head>
  <body>
    <div class="entrance">
    <main class="card">
      <header>
        <h1>{profile.name}</h1>
        <p class="title">{profile.title}</p>
      </header>

      <div class="sp" aria-hidden="true"></div>
      <div class="lower">
      <nav aria-label="Links">
        <a href={profile.github} aria-label="GitHub" title="GitHub">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path
              d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55 0-.27-.01-1.17-.02-2.12-3.2.7-3.88-1.36-3.88-1.36-.52-1.33-1.28-1.68-1.28-1.68-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.19 1.76 1.19 1.03 1.76 2.69 1.25 3.35.96.1-.75.4-1.25.72-1.54-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.28 1.19-3.09-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.17 1.18a11 11 0 0 1 5.77 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.83 1.19 3.09 0 4.42-2.7 5.39-5.26 5.68.41.35.78 1.05.78 2.12 0 1.53-.01 2.76-.01 3.14 0 .3.2.67.8.55A11.51 11.51 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z"
            ></path>
          </svg>
        </a>
        <a href={profile.linkedin} aria-label="LinkedIn" title="LinkedIn">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path
              d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05a3.74 3.74 0 0 1 3.37-1.85c3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12ZM7.12 20.45H3.56V9h3.56v11.45ZM22.22 0H1.77C.79 0 0 .77 0 1.72v20.55C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.72C24 .77 23.2 0 22.22 0Z"
            ></path>
          </svg>
        </a>
        <a href={`mailto:${profile.email}`} aria-label="Email" title="Email">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <rect x="2" y="4" width="20" height="16" rx="2"></rect>
            <path d="m2 7 10 6 10-6"></path>
          </svg>
        </a>
      </nav>

      <div class="certs">
        {
          certifications.map((c) => (
            <a href={c.url} class="cert" title={c.name}>
              <img src={c.badge} alt="" width="72" height="72" loading="lazy" />
              <span>{c.abbr}</span>
            </a>
          ))
        }
      </div>
      </div>
    </main>
    </div>
    <canvas id="dots" aria-hidden="true"></canvas>
    <script>
      const card = document.querySelector('.card') as HTMLElement;
      const root = document.documentElement;
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (!reduced) {
        document.addEventListener('pointermove', (e) => {
          const dx = (e.clientX - innerWidth / 2) / (innerWidth / 2);
          const dy = (e.clientY - innerHeight / 2) / (innerHeight / 2);
          root.style.setProperty('--tiltX', `${dy * -7}deg`);
          root.style.setProperty('--tiltY', `${dx * 7}deg`);
          shTarget = { x: dx * -14, y: dy * -14 };
        });
      }

      const canvas = document.getElementById('dots') as HTMLCanvasElement;
      const ctx = canvas.getContext('2d')!;
      const CELL = 82;
      const LINK = 110;
      const RADIUS = 110;
      const PUSH = 18;
      let dots: {
        hx: number; hy: number; x: number; y: number;
        r: number; a: number; bright: boolean;
      }[] = [];
      let mouse = { x: -9999, y: -9999 };
      let star: { x: number; y: number; vx: number; vy: number; life: number } | null = null;

      function spawnStar() {
        const fromLeft = Math.random() < 0.5;
        const ang = (fromLeft ? 0.15 : Math.PI - 0.15) + (Math.random() - 0.5) * 0.4;
        star = {
          x: fromLeft ? -20 : innerWidth + 20,
          y: Math.random() * innerHeight * 0.4,
          vx: Math.cos(ang) * 11,
          vy: Math.abs(Math.sin(ang)) * 11 + 2.5,
          life: 1,
        };
        wake();
      }

      function scheduleStar(delay: number) {
        setTimeout(() => {
          spawnStar();
          scheduleStar(20000 + Math.random() * 20000);
        }, delay);
      }

      const PAD = 80;
      const baseCanvas = document.createElement('canvas');
      const shadowCanvas = document.createElement('canvas');
      let cardRect = { l: 0, t: 0, r: 0, b: 0 };
      let sh = { x: 0, y: 0 };
      let shTarget = { x: 0, y: 0 };

      function renderGlow() {
        const w = innerWidth + PAD * 2;
        const h = innerHeight + PAD * 2;
        baseCanvas.width = w;
        baseCanvas.height = h;
        shadowCanvas.width = w;
        shadowCanvas.height = h;
        const bctx = baseCanvas.getContext('2d')!;
        const sctx = shadowCanvas.getContext('2d')!;
        const imgB = bctx.createImageData(w, h);
        const img = sctx.createImageData(w, h);
        const dB = imgB.data;
        const d = img.data;
        const g1 = { cx: 0.2 * w, cy: 0.15 * h, rx: 0.6 * w, ry: 0.5 * h, r: 203, gc: 166, b: 247, a: 0.09 };
        const g2 = { cx: 0.8 * w, cy: 0.85 * h, rx: 0.55 * w, ry: 0.45 * h, r: 137, gc: 180, b: 250, a: 0.08 };
        const cl = (innerWidth - card.offsetWidth) / 2 + PAD;
        const ct = (innerHeight - card.offsetHeight) / 2 + PAD + 8;
        const cr = cl + card.offsetWidth;
        const cb = ct + card.offsetHeight;
        cardRect = { l: cl - PAD, t: ct - PAD, r: cr - PAD, b: cb - PAD };
        for (let y = 0; y < h; y++) {
          for (let x = 0; x < w; x++) {
            let r = 30, g = 30, b = 46;
            for (const gl of [g1, g2]) {
              const t = Math.hypot((x - gl.cx) / gl.rx, (y - gl.cy) / gl.ry);
              const a = t < 0.7 ? gl.a * (1 - t / 0.7) : 0;
              if (a > 0) {
                r += (gl.r - r) * a;
                g += (gl.gc - g) * a;
                b += (gl.b - b) * a;
              }
            }
            const n = Math.random() - 0.5;
            const i = (y * w + x) * 4;
            dB[i] = r + n;
            dB[i + 1] = g + n;
            dB[i + 2] = b + n;
            dB[i + 3] = 255;
            const sdx = Math.max(cl - x, 0, x - cr);
            const sdy = Math.max(ct - y, 0, y - cb);
            const sd = Math.hypot(sdx, sdy);
            const shade = 0.16 * Math.exp(-sd / 20);
            d[i] = (r + n) * (1 - shade);
            d[i + 1] = (g + n) * (1 - shade);
            d[i + 2] = (b + n) * (1 - shade);
            d[i + 3] = 255;
          }
        }
        bctx.putImageData(imgB, 0, 0);
        sctx.putImageData(img, 0, 0);
      }

      function layout() {
        const dpr = devicePixelRatio || 1;
        canvas.width = innerWidth * dpr;
        canvas.height = innerHeight * dpr;
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        dots = [];
        for (let y = 0; y < innerHeight; y += CELL)
          for (let x = 0; x < innerWidth; x += CELL) {
            const hx = x + Math.random() * CELL;
            const hy = y + Math.random() * CELL;
            const bright = Math.random() < 1 / 15;
            dots.push({
              hx, hy, x: hx, y: hy,
              r: bright ? 2 + Math.random() * 0.8 : 1 + Math.random(),
              a: bright ? 0.72 + Math.random() * 0.22 : 0.5 + Math.random() * 0.5,
              bright,
            });
          }
        renderGlow();
        if (reduced) draw();
      }

      function draw() {
        ctx.drawImage(baseCanvas, -PAD, -PAD);
        const m = 140;
        const rx = cardRect.l - m;
        const ry = cardRect.t - m;
        const rw = cardRect.r - cardRect.l + m * 2;
        const rh = cardRect.b - cardRect.t + m * 2;
        ctx.drawImage(shadowCanvas, rx + PAD - sh.x, ry + PAD - sh.y, rw, rh, rx, ry, rw, rh);
        ctx.strokeStyle = 'rgba(69, 71, 90, 1)';
        for (let i = 0; i < dots.length; i++) {
          for (let j = i + 1; j < dots.length; j++) {
            const a = dots[i], b = dots[j];
            const dx = a.x - b.x;
            if (dx > LINK || dx < -LINK) continue;
            const dist = Math.hypot(dx, a.y - b.y);
            if (dist < LINK) {
              ctx.globalAlpha = 0.45 * (1 - dist / LINK);
              ctx.beginPath();
              ctx.moveTo(a.x, a.y);
              ctx.lineTo(b.x, b.y);
              ctx.stroke();
            }
          }
        }
        for (const d of dots) {
          const md = Math.hypot(d.x - mouse.x, d.y - mouse.y);
          const boost = md < RADIUS ? (1 - md / RADIUS) * 0.5 : 0;
          if (d.bright) {
            ctx.globalAlpha = 0.08 + boost * 0.3;
            ctx.fillStyle = '#b4befe';
            ctx.beginPath();
            ctx.arc(d.x, d.y, d.r * 3, 0, Math.PI * 2);
            ctx.fill();
          }
          ctx.globalAlpha = Math.min(1, d.a + boost);
          ctx.fillStyle = d.bright ? '#b4befe' : 'rgb(88, 91, 112)';
          ctx.beginPath();
          ctx.arc(d.x, d.y, d.r, 0, Math.PI * 2);
          ctx.fill();
        }
        ctx.globalAlpha = 1;

        if (star) {
          ctx.strokeStyle = '#b4befe';
          ctx.lineWidth = 1.5;
          ctx.globalAlpha = 0.6 * star.life;
          ctx.beginPath();
          ctx.moveTo(star.x, star.y);
          ctx.lineTo(star.x - star.vx * 5, star.y - star.vy * 5);
          ctx.stroke();
          ctx.globalAlpha = 1;
          ctx.lineWidth = 1;
        }
      }

      let running = false;

      function tick() {
        let moving = false;
        sh.x += (shTarget.x - sh.x) * 0.12;
        sh.y += (shTarget.y - sh.y) * 0.12;
        if (Math.abs(shTarget.x - sh.x) > 0.1 || Math.abs(shTarget.y - sh.y) > 0.1) moving = true;
        if (star) {
          star.x += star.vx;
          star.y += star.vy;
          star.life -= 0.007;
          if (star.life <= 0 || star.y > innerHeight + 40) star = null;
          else moving = true;
        }
        for (const d of dots) {
          const dx = d.hx - mouse.x;
          const dy = d.hy - mouse.y;
          const dist = Math.hypot(dx, dy);
          let tx = d.hx;
          let ty = d.hy;
          if (dist < RADIUS && dist > 0) {
            const f = (1 - dist / RADIUS) * PUSH;
            tx += (dx / dist) * f;
            ty += (dy / dist) * f;
            moving = true;
          }
          d.x += (tx - d.x) * 0.12;
          d.y += (ty - d.y) * 0.12;
          if (Math.abs(tx - d.x) > 0.05 || Math.abs(ty - d.y) > 0.05) moving = true;
        }
        draw();
        if (moving) {
          requestAnimationFrame(tick);
        } else {
          running = false;
        }
      }

      function wake() {
        if (!running) {
          running = true;
          requestAnimationFrame(tick);
        }
      }

      layout();
      addEventListener('resize', layout);
      if (!reduced) {
        document.addEventListener('pointermove', (e) => {
          mouse = { x: e.clientX, y: e.clientY };
          wake();
        });
        document.addEventListener('pointerleave', () => {
          mouse = { x: -9999, y: -9999 };
          wake();
        });
        wake();
        scheduleStar(10000);
      }
    </script>
  </body>
</html>

<style is:global>
  :root {
    --base: #1e1e2e;
    --mantle: #181825;
    --text: #cdd6f4;
    --subtext: #a6adc8;
    --overlay: #6c7086;
    --mauve: #cba6f7;
    --blue: #89b4fa;
    --green: #a6e3a1;
    --surface: #313244;
    --tiltX: 0deg;
    --tiltY: 0deg;
  }

  * {
    margin: 0;
    box-sizing: border-box;
  }

  body {
    background: var(--base);
    color: var(--text);
    font-family: system-ui, -apple-system, sans-serif;
    min-height: 100dvh;
    display: grid;
    place-items: center;
    padding: 1.25rem;
  }

  #dots {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
  }

  .card {
    background: var(--mantle);
    border: 1px solid var(--surface);
    border-radius: 16px;
    padding: 2.5rem 2.75rem;
    min-width: min(23.5rem, calc(100vw - 2.5rem));
    min-height: min(27rem, calc(100dvh - 2.5rem));
    display: flex;
    flex-direction: column;
    text-align: center;
    transform: perspective(800px) rotateX(var(--tiltX)) rotateY(var(--tiltY));
    transition: transform 0.15s ease-out;
  }

  .entrance {
    animation: enter 0.45s ease-out both;
  }

  @keyframes enter {
    from {
      opacity: 0;
      translate: 0 14px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .entrance {
      animation: none;
    }
  }

  h1 {
    font-size: 1.9rem;
    font-weight: 700;
    color: var(--text);
  }

  .title {
    color: var(--subtext);
    margin-top: 0.25rem;
    font-family: ui-monospace, 'Cascadia Code', monospace;
  }

  .sp {
    flex-grow: 1.618;
  }

  .card::after {
    content: '';
    flex-grow: 1;
  }

  .lower {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  nav {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
  }

  nav a {
    color: var(--subtext);
    display: inline-flex;
  }

  nav a:hover {
    color: var(--blue);
  }

  nav a:first-child:hover {
    color: var(--mauve);
  }

  nav a:last-child:hover {
    color: var(--green);
  }

  nav svg {
    width: 1.6rem;
    height: 1.6rem;
  }

  .certs {
    display: flex;
    justify-content: center;
    gap: 2rem;
  }

  .cert {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    text-decoration: none;
    color: var(--overlay);
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    transition: transform 0.15s ease;
  }

  .cert:hover {
    transform: translateY(-3px);
    color: var(--text);
  }
</style>
